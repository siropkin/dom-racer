    "test:watch": "vitest",
    "typecheck": "tsc"
  },
  "devDependencies": {
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
