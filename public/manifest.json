{
  "manifest_version": 3,
  "name": "DOM Racer",
  "version": "0.1.0",
  "description": "Turn visible page elements into a playable retro top-down racer.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
